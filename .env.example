# ============================================================================
# .env.example — AumOS LLM Serving Service
# ============================================================================
# Copy to .env and customize for local development:
#   cp .env.example .env
# ============================================================================

# Service Identity
AUMOS_SERVICE_NAME=aumos-llm-serving
AUMOS_ENVIRONMENT=development
AUMOS_DEBUG=true

# Database (PostgreSQL 16 + pgvector + RLS)
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos
AUMOS_DATABASE__POOL_SIZE=10
AUMOS_DATABASE__ECHO=false

# Kafka (Apache Kafka + Protobuf Schema Registry)
AUMOS_KAFKA__BROKERS=localhost:9092
AUMOS_KAFKA__SCHEMA_REGISTRY_URL=http://localhost:8081

# Authentication (Keycloak)
AUMOS_KEYCLOAK__URL=http://localhost:8080
AUMOS_KEYCLOAK__REALM=aumos
AUMOS_KEYCLOAK__CLIENT_ID=aumos-llm-serving
AUMOS_KEYCLOAK__CLIENT_SECRET=dev-secret-change-in-production

# Observability
AUMOS_OTEL_ENDPOINT=http://localhost:4317
AUMOS_OTEL_ENABLED=false
AUMOS_LOG_LEVEL=DEBUG
AUMOS_LOG_FORMAT=console

# Secrets (OpenBao / Vault)
AUMOS_VAULT__URL=http://localhost:8200
AUMOS_VAULT__TOKEN=dev-root-token

# Redis (for rate limiting)
AUMOS_REDIS__URL=redis://localhost:6379/0

# ============================================================================
# LLM SERVING SPECIFIC SETTINGS (prefix: AUMOS_LLM_)
# ============================================================================

# vLLM (production GPU serving)
AUMOS_LLM__VLLM_BASE_URL=http://localhost:8080
AUMOS_LLM__VLLM_API_KEY=

# Ollama (development / small deployments)
AUMOS_LLM__OLLAMA_BASE_URL=http://localhost:11434

# LiteLLM config file path (YAML with provider routing rules)
AUMOS_LLM__LITELLM_CONFIG_PATH=/app/config/litellm_config.yaml

# Default model to use when none specified
AUMOS_LLM__DEFAULT_MODEL=ollama/llama3.2

# OpenAI (via LiteLLM or direct)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (via LiteLLM)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Azure OpenAI (via LiteLLM)
AZURE_API_KEY=your-azure-key-here
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-01

# Cost tracking
AUMOS_LLM__ENABLE_COST_TRACKING=true
AUMOS_LLM__COST_ALERT_THRESHOLD_USD=100.0

# Rate limiting
AUMOS_LLM__RATE_LIMIT_WINDOW_SECONDS=60
AUMOS_LLM__DEFAULT_RPM_LIMIT=60
AUMOS_LLM__DEFAULT_TPM_LIMIT=100000
